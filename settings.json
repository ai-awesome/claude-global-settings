{
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/try-say.sh 'Construction in progress.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/try-say.sh 'Good day, commander. I am here!'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/try-say.sh \"$(cat /dev/stdin | jq -r '.last_assistant_message' | head -1)\""
          }
        ]
      }
    ]
  }
}
